    const c=cardRect(i),ch=CHARS[CHAR_ORDER[i]],sel=i===selIdx;
    ctx.fillStyle=sel?'rgba(255,211,92,.14)':'rgba(255,255,255,.05)';
    ctx.strokeStyle=sel?'#ffd35c':'rgba(255,255,255,.25)';
    ctx.lineWidth=sel?4:2;
    ctx.fillRect(c.x,c.y,c.w,c.h); ctx.strokeRect(c.x,c.y,c.w,c.h);
    drawMini(CHAR_ORDER[i],c.x+c.w/2,c.y+178,.82,now);
    ctx.textAlign='center'; ctx.textBaseline='top';
    ctx.font='900 24px "Arial Black",system-ui'; ctx.fillStyle='#fff';
    ctx.fillText(ch.name,c.x+c.w/2,c.y+196);
    ctx.font='700 12px system-ui'; ctx.fillStyle='rgba(255,233,201,.75)';
    ctx.fillText(ch.tag,c.x+c.w/2,c.y+226);
    ctx.font='800 14px system-ui'; ctx.fillStyle=ch.accent;
    ctx.fillText('★ '+ch.spName,c.x+c.w/2,c.y+250);
    ctx.font='700 11px system-ui'; ctx.fillStyle='rgba(255,255,255,.75)';
    ctx.fillText(ch.spDesc,c.x+c.w/2,c.y+270);
    statRow('PWR',ch.stats.p,c.x+16,c.y+294,c.w-32);
    statRow('SPD',ch.stats.s,c.x+16,c.y+312,c.w-32);
    statRow('JMP',ch.stats.j,c.x+16,c.y+330,c.w-32);
  }
  ctx.textAlign='center'; ctx.font='800 16px system-ui';
  ctx.fillStyle=Math.sin(now*.006)>0?'#ffe9c9':'rgba(255,233,201,.3)';
  ctx.fillText(isTouch?'TAP A FIGHTER TO BEGIN':'ARROWS + ENTER, OR CLICK A FIGHTER',VW/2,VH-30);
}
function drawVS(now){
  STAGES[game.stage].draw(game.camX);
  ctx.fillStyle='rgba(8,4,16,.66)'; ctx.fillRect(0,0,VW,VH);
  drawMini(p1.char.key,VW*.27,VH*.72,1.5,now);
  ctx.save(); ctx.translate(VW*.73,VH*.72); ctx.scale(-1,1); ctx.translate(-VW*.73,-VH*.72);
  drawMini(p2.char.key,VW*.73,VH*.72,1.5,now);
  ctx.restore();
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.font='900 84px "Arial Black",system-ui';
  ctx.lineWidth=12; ctx.strokeStyle='#33121f'; ctx.strokeText('VS',VW/2,VH*.42);
  ctx.fillStyle='#ffd35c'; ctx.fillText('VS',VW/2,VH*.42);
  ctx.font='900 34px "Arial Black",system-ui'; ctx.fillStyle='#fff';
  ctx.lineWidth=7;
  ctx.strokeText(p1.char.name,VW*.27,VH*.3); ctx.fillText(p1.char.name,VW*.27,VH*.3);
  ctx.strokeText(p2.char.name,VW*.73,VH*.3); ctx.fillText(p2.char.name,VW*.73,VH*.3);
  ctx.font='800 20px system-ui'; ctx.fillStyle='#ffe9c9';
  ctx.fillText('LEVEL '+game.level+' · '+STAGES[game.stage].name,VW/2,VH*.14);
}

/* ---------------- Main loop ---------------- */
let last=performance.now(),dtGlobal=0;
function frame(now){
  requestAnimationFrame(frame);
  let dt=Math.min((now-last)/1000,1/30); last=now; dtGlobal=dt;
  if(game.freeze>0){ game.freeze-=dt; dt=0; }

  const inFight=['intro','fight','ko'].includes(game.state);
  wrap.classList.toggle('nohud',!inFight);
  const fighting=game.state==='fight';

  p1.inp.left=kbHeld.left||stkL; p1.inp.right=kbHeld.right||stkR; p1.inp.block=kbHeld.block||stkD;
  if(taps.punch>0){p1.buf.punch=taps.punch; taps.punch=0;}
  if(taps.kick>0){p1.buf.kick=taps.kick; taps.kick=0;}
  if(taps.jump>0){p1.buf.jump=taps.jump; taps.jump=0;}
  if(taps.sp>0){p1.buf.sp=taps.sp; taps.sp=0;}

  if(dt>0&&game.moonT>0){
    game.moonT-=dt;
    if(Math.random()<dt*7)
      parts.push({t:'p',x:game.camX+rnd(0,VW),y:rnd(40,300),vx:rnd(-14,14),vy:rnd(16,42),
        life:rnd(.8,1.5),max:1.5,col:'#cfe0ff',g:false});
    if(game.moonT<=0&&game.moonCaster) game.moonCaster.spCd=6;
  }

  if(fighting&&dt>0){
    aiThink(p2,p1,dt);
    game.time-=dt;
    if(game.time<=0) timeUp();
  }

  if(dt>0&&!['title','select','vs'].includes(game.state)){
    updateFighter(p1,p2,dt,fighting);
    updateFighter(p2,p1,dt,fighting);
    if(fighting){
      const ad=Math.abs(p1.x-p2.x);
      const dashing=f=>f.state==='special'&&f.spType==='dash';
      if(ad<52&&grounded(p1)&&grounded(p2)&&p1.state!=='ko'&&p2.state!=='ko'&&!dashing(p1)&&!dashing(p2)){
        const push=(52-ad)/2,s=p1.x<p2.x?1:-1;
        p1.x=clamp(p1.x-push*s,50,STAGE_W-50);
        p2.x=clamp(p2.x+push*s,50,STAGE_W-50);
      }
    }
  }

  computePose(p1,now); computePose(p2,now);
  computeSkeleton(p1); computeSkeleton(p2);

  if(fighting&&dt>0){ tryHits(p1,p2); tryHits(p2,p1); }
  if(dt>0) updateProjs(dt,fighting);

  game.stT+=dt; game.msgT+=dt;
  if(game.state==='intro'){
    if(game.stT>1.05&&game.stT-dt<=1.05){ showMsg('FIGHT!',null,.6); sfx.bell(); }
    if(game.stT>1.65) game.state='fight';
  }
  if(game.state==='vs'&&game.stT>1.7) startRound(1);
  if(game.state==='levelclear'&&game.stT>1.8){
    game.level++;
    if(game.level>3) champion();
    else { setupLevel(); game.state='vs'; game.stT=0; }
  }
  if(game.state==='ko'&&game.stT>1.9){
    const wi=game.winner===p1?0:1;
    game.wins[wi]++;
    if(game.wins[wi]>=2){ wi===0?levelClear():gameOver(); }
    else startRound(game.round+1);
  }
  if(game.state==='champion'&&Math.random()<.5) confetti();

  for(const f of [p1,p2]) f.dispHp=Math.max(f.hp,f.dispHp-f.maxHp*.3*Math.max(dt,0));
  updateParts(Math.max(dt,.001)*(game.freeze>0?.3:1));

  const mid=(p1.x+p2.x)/2;
  game.camX=lerp(game.camX,clamp(mid-VW/2,0,STAGE_W-VW),1-Math.exp(-6*Math.max(dt,.001)));
  game.shake*=Math.exp(-7*Math.max(dt,.001));

  render(now);
}

function render(now){
  ctx.setTransform(1,0,0,1,0,0);
  ctx.fillStyle='#0d0716'; ctx.fillRect(0,0,cv.width,cv.height);
  ctx.setTransform(scale,0,0,scale,offX,offY);
  ctx.save();
  ctx.beginPath(); ctx.rect(0,0,VW,VH); ctx.clip();

  const st=game.state;
  if(st==='select'){ drawSelect(now); }
  else if(st==='vs'){ drawVS(now); }
  else{
    const shX=rnd(-1,1)*game.shake,shY=rnd(-1,1)*game.shake;
    STAGES[game.stage].draw(game.camX);
    moonOverlay();
    ctx.save();
    ctx.translate(-game.camX+shX,shY);
    drawProps();
    drawFighter(p2,now);
    drawFighter(p1,now);
    drawProjs();
    drawParts();
    ctx.restore();

    if(st==='title'){
      ctx.fillStyle='rgba(10,4,18,.38)'; ctx.fillRect(0,0,VW,VH);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.font='900 80px "Arial Black",system-ui';
      ctx.lineWidth=12; ctx.strokeStyle='#33121f';
      ctx.strokeText('SUNSET',VW/2,132);
      ctx.fillStyle='#ffd35c'; ctx.fillText('SUNSET',VW/2,132);
      ctx.strokeText('SHOWDOWN II',VW/2,212);
      ctx.fillStyle='#fff'; ctx.fillText('SHOWDOWN II',VW/2,212);
      ctx.font='800 24px system-ui';
      ctx.fillStyle=Math.sin(now*.006)>0?'#ffe9c9':'rgba(255,233,201,.25)';
      ctx.fillText(isTouch?'TAP TO START':'CLICK OR PRESS ENTER TO START',VW/2,320);
      ctx.font='700 16px system-ui'; ctx.fillStyle='rgba(255,255,255,.65)';
      ctx.fillText('4 fighters · 3 levels · specials · double jump · dive kicks',VW/2,362);
    }else{
      hud(now);
    }
  }
  if(game.msg&&game.msgT<game.msg.dur) bigText(game.msg.t,game.msg.sub,game.msgT);
  ctx.restore();
}

resetFighters();
requestAnimationFrame(frame);
</script>
