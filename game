  #bJ{right:calc(70px + env(safe-area-inset-right));bottom:calc(150px + env(safe-area-inset-bottom))}
  #bP{right:calc(132px + env(safe-area-inset-right));bottom:calc(78px + env(safe-area-inset-bottom))}
