<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
<title>Sunset Showdown II</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none;-webkit-user-select:none}
  html,body{height:100%;overflow:hidden;background:#0d0716;font-family:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif}
  #wrap{position:fixed;inset:0;overflow:hidden}
  canvas{position:absolute;inset:0;width:100%;height:100%;display:block;touch-action:none}
  .btn{
    position:absolute;width:64px;height:64px;border-radius:50%;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    color:#fff;font-weight:800;font-size:22px;line-height:1;
